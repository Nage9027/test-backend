# ----------------------------------------------------------------------------
# Backend environment template — copy to `.env` and fill in real values.
# ----------------------------------------------------------------------------

# Postgres connection used by Prisma at runtime.
# For Supabase use the pooler URL (port 6543) for serverless, or the
# direct connection (port 5432) for traditional servers.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Direct (non-pooled) URL used by `prisma migrate` etc.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Long, random string used to sign JWTs. Generate one with
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-me-with-a-long-random-string"

# HTTP port the API listens on locally.
PORT=5000

# Comma-separated list of origins allowed by CORS.
# Example for local + Railway:
#   CLIENT_URL="http://localhost:5173,https://taskflow.up.railway.app"
CLIENT_URL="http://localhost:5173"
